Robots Table

CREATE TABLE `robots` (
	`RobotRecord` INT(3) UNSIGNED NOT NULL,
	`DeviceID` INT(5) UNSIGNED NOT NULL,
	`DeviceName` VARCHAR(20) NOT NULL COLLATE 'utf8mb4_unicode_ci',
	`EnergyUsage` VARCHAR(20) NULL DEFAULT NULL COLLATE 'utf8mb4_unicode_ci',
	`UsageTime (Daily)` VARCHAR(25) NULL DEFAULT NULL COLLATE 'utf8mb4_unicode_ci',
	`UsageTime (Weekly)` VARCHAR(25) NULL DEFAULT NULL COLLATE 'utf8mb4_unicode_ci',
	`UsageTime (Monthly)` VARCHAR(25) NULL DEFAULT NULL COLLATE 'utf8mb4_unicode_ci',
	PRIMARY KEY (`RobotRecord`) USING BTREE,
	INDEX `FK_robots_alldevices` (`DeviceID`) USING BTREE,
	CONSTRAINT `FK_robots_alldevices` FOREIGN KEY (`DeviceID`) REFERENCES `alldevices` (`DeviceID`) ON UPDATE NO ACTION ON DELETE NO ACTION
)
COMMENT='detailed information on devices of category robot.'
COLLATE='utf8mb4_unicode_ci'
ENGINE=InnoDB
;
















