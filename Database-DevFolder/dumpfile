Home Details Table

CREATE TABLE `homedetails` (
	`HomeID` INT(3) UNSIGNED NOT NULL AUTO_INCREMENT,
	`NoOfResidents` INT(3) UNSIGNED NOT NULL,
	`TotalEnergyUsage (Daily)` VARCHAR(30) NOT NULL COLLATE 'utf8mb4_unicode_ci',
	`TotalEnergyUsage (Weekly)` VARCHAR(30) NOT NULL COLLATE 'utf8mb4_unicode_ci',
	`TotalEnergyUsage (Monthly)` VARCHAR(30) NOT NULL COLLATE 'utf8mb4_unicode_ci',
	`TotalEnergyGeneration (Daily)` VARCHAR(30) NOT NULL COLLATE 'utf8mb4_unicode_ci',
	`TotalEnergyGeneration (Weekly)` VARCHAR(30) NOT NULL COLLATE 'utf8mb4_unicode_ci',
	`TotalEnergyGeneration (Monthly)` VARCHAR(30) NOT NULL COLLATE 'utf8mb4_unicode_ci',
	`HomeManager` VARCHAR(30) NULL DEFAULT NULL COLLATE 'utf8mb4_unicode_ci',
	PRIMARY KEY (`HomeID`) USING BTREE
)
COMMENT='table containing house details'
COLLATE='utf8mb4_unicode_ci'
ENGINE=InnoDB
;

