-- select sum of all energyhourly values for a specific day for all devices in a given homeID
SELECT SUM(EnergyVal) AS TotalDailyValue
FROM energyhourly
JOIN alldevices ON energyhourly.DeviceID = alldevices.DeviceID
JOIN homedetails ON alldevices.HomeID = homedetails.HomeID
WHERE homedetails.HomeID = 1 AND energyhourly.Date = "2025-03-11"

-- select sum of energyhourly energy values for a specific device and day
SELECT SUM(EnergyVal) AS DeviceDailyValue
FROM energyhourly
JOIN alldevices ON energyhourly.DeviceID = alldevices.DeviceID
WHERE alldevices.DeviceID = 1 AND energyhourly.Date = "2025-03-11"

