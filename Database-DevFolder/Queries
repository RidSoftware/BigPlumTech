-- This should pull summed energyValue for a hour for all devices tied to a user via email
SELECT SUM(e.energyValue) AS totalEnergy
FROM hourlyEnergyValues e
JOIN deviceDetails d ON e.deviceID = d.deviceID
JOIN userDetails u ON u.homeID = d.homeID
WHERE u.email = ? AND e.Hour = ? AND e.Date = ?;
