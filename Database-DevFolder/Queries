-- This should pull summed energyValue for a specific hour and specific date for all devices tied to a user via email (should probably give user local storage a version of userID so we dont need the extra step here)
SELECT SUM(EnergyVal) AS totalEnergy
FROM energyhourly
JOIN alldevices ON energyhourly.DeviceID = alldevices.DeviceID
JOIN homedetails ON homedetails.HomeID = alldevices.HomeID
WHERE homedetails.HomeID = 3 AND energyhourly.Hour = 3 AND energyhourly.Date = "2025-03-11";

